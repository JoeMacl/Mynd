<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F7F4EF">

    <TextView
        android:id="@+id/promptTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Memory Activity"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#2F3A35"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/promptText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Question"
        android:textSize="24sp"
        android:textColor="#4F5D55"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/optionOneButton"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:text="Option 1"
        android:textSize="24sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/optionTwoButton"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:text="Option 2"
        android:textSize="24sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/optionThreeButton"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:text="Option 3"
        android:textSize="24sp"
        android:layout_marginBottom="24dp" />



    <Button
        android:id="@+id/homeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Return to Home"
        android:layout_marginTop="16dp" />

</LinearLayout>